# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Intelligent Trip Planner"
DEBUG=false

# ── LLM provider ──────────────────────────────────────────────────────────────
# Options: mock | openai | claude
LLM_PROVIDER=mock

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-20241022

# ── Maps / routing provider ───────────────────────────────────────────────────
# Options: mock | google | amap
# mock  → straight-line Haversine distance, no key needed
# google → Google Maps Distance Matrix + Directions API
# amap   → Amap (高德) Web API, better coverage for mainland China
MAPS_PROVIDER=mock

GOOGLE_MAPS_API_KEY=
AMAP_API_KEY=

# ── POI data provider ─────────────────────────────────────────────────────────
# Options: mock | google_places
# mock          → reads from app/data/mock/{destination}_pois.json
# google_places → Google Places Nearby Search + Place Details
POI_PROVIDER=mock

# Google Places uses the same key as Google Maps (one key covers both)
GOOGLE_PLACES_API_KEY=

# ── Weather provider ──────────────────────────────────────────────────────────
# Options: mock | openweathermap
# mock          → returns seasonally-appropriate fixed forecast
# openweathermap → 5-day / 3-hour forecast, free plan supported
WEATHER_PROVIDER=mock

OPENWEATHERMAP_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./trip_planner.db

# ── Scoring weights (must sum to 1.0) ────────────────────────────────────────
SCORE_WEIGHT_INTEREST=0.55
SCORE_WEIGHT_POPULARITY=0.25
SCORE_WEIGHT_BUDGET=0.20

# ── Planning parameters ───────────────────────────────────────────────────────
DAILY_HOURS_BUDGET=8.0
TRANSPORT_BUFFER_MINUTES=15
